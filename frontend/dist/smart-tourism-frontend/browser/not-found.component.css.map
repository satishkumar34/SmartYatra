
    .not-found {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--dark-950);
      padding: 2rem;
    }

    .nf-content {
      text-align: center;
      max-width: 480px;
    }

    .nf-code {
      font-size: 8rem;
      font-weight: 700;
      line-height: 1;
      background: linear-gradient(135deg, #b8932a, #c9a84c, #e0c070);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1rem;
    }

    .nf-title {
      font-size: 1.875rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 1rem;
    }

    .nf-sub {
      color: var(--text-muted);
      font-size: 1rem;
      margin-bottom: 2.5rem;
      line-height: 1.7;
    }

    .nf-actions {
      display: flex;
      gap: 1rem;
      justify-content: center;
      flex-wrap: wrap;
    }
  